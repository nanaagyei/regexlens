# ===========================================
# RegexLens Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# ===========================================
# Database (Docker default - no changes needed for local dev)
# ===========================================
# WARNING: The credentials below (`regexlens` / `regexlens_dev`) are intended
# for LOCAL DEVELOPMENT ONLY. Production deployments MUST use unique, strong
# credentials. The instrumentation hook (src/instrumentation.ts) logs a
# startup warning if these defaults are detected with NODE_ENV=production.
DATABASE_URL=postgresql://regexlens:regexlens_dev@localhost:5433/regexlens

# ===========================================
# Authentication (Auth.js)
# ===========================================
# REQUIRED: Generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical site origin for server-side redirects (OAuth). Set in Vercel Production.
# Local: http://localhost:3000
# Vercel Production: https://regexlens.dev (use one host; add www→apex redirect in Vercel if both exist)
NEXTAUTH_URL=http://localhost:3000
# Auth.js v5 also reads AUTH_URL; set to the same value as NEXTAUTH_URL if you use it
# AUTH_URL=http://localhost:3000

# GitHub OAuth (required - at least one OAuth provider needed)
# Create at: https://github.com/settings/developers
# Callback URLs (add both in the OAuth app, or use separate apps per environment):
#   Local: http://localhost:3000/api/auth/callback/github
#   Production: https://regexlens.dev/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (optional)
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add every host you use — must match exactly):
#   Local: http://localhost:3000/api/auth/callback/google
#   Production: https://regexlens.dev/api/auth/callback/google
#   If www is used: https://www.regexlens.dev/api/auth/callback/google
# Authorized JavaScript origins: https://regexlens.dev, https://www.regexlens.dev, http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email Magic Links via Resend (optional)
# Get API key at: https://resend.com
# Used by src/auth.ts; RESEND_API_KEY is a supported alias (Resend docs name)
AUTH_RESEND_KEY=
# RESEND_API_KEY=
# Local: noreply@localhost — Production: verified sender, e.g. RegexLens <noreply@regexlens.dev>
EMAIL_FROM=noreply@localhost

# ===========================================
# Rate Limiting - Redis
# ===========================================
# Production requires REDIS_URL; requests fail closed when missing.
# Non-production can use an in-memory fallback to keep local/CI stable.
REDIS_URL=

# Set to 0 to disable non-production in-memory fallback and fail closed instead.
# Ignored in production.
RATE_LIMIT_ALLOW_FALLBACK_WITHOUT_REDIS=1

# ===========================================
# Site Configuration
# ===========================================
# Public site URL (metadata, canonical URLs, sitemap, legal pages).
# Production: https://regexlens.dev — for local dev you can override in .env.local:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://regexlens.dev

# Documentation (Nextra on GitHub Pages — custom subdomain)
NEXT_PUBLIC_DOCS_URL=https://docs.regexlens.dev

# Vercel Web Analytics + Speed Insights (@vercel/analytics, @vercel/speed-insights)
# Set to 0 to disable instrumentation client bundles locally or on a preview
# NEXT_PUBLIC_VERCEL_ANALYTICS=0

# Ads (optional) — enable only after you have a consent/CMP strategy for your regions
# NEXT_PUBLIC_ADS_ENABLED=1
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx

# Sponsorship / support link (optional)
# NEXT_PUBLIC_SUPPORT_URL=https://buymeacoffee.com/nanaagyei

# ===========================================
# AI Features (Bring Your Own Key)
# ===========================================
# ANTHROPIC_API_KEY is NOT used server-side. AI features use a bring-your-own-key
# model where users provide their own Anthropic API key via the browser UI.
# Keys are stored only in the user's browser (48-hour auto-expiry) and sent
# per-request via the X-Anthropic-Key header — never persisted on the server.

# ===========================================
# SEO Verification (optional)
# ===========================================
# Google Search Console verification code
GOOGLE_SITE_VERIFICATION=

# Yandex Webmaster verification code
YANDEX_VERIFICATION=

# Bing Webmaster verification code (if needed)
# BING_VERIFICATION=
