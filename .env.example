# ===========================================
# RegexLens Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# ===========================================
# Database (Docker default - no changes needed for local dev)
# ===========================================
DATABASE_URL=postgresql://regexlens:regexlens_dev@localhost:5433/regexlens

# ===========================================
# Authentication (Auth.js)
# ===========================================
# REQUIRED: Generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical site origin for server-side redirects (OAuth).
# Local: http://localhost:3000
# Vercel Production: https://regexlens.dev
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (required - at least one OAuth provider needed)
# Create at: https://github.com/settings/developers
# Callback URLs (add both in the OAuth app, or use separate apps per environment):
#   Local: http://localhost:3000/api/auth/callback/github
#   Production: https://regexlens.dev/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (optional)
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URLs:
#   Local: http://localhost:3000/api/auth/callback/google
#   Production: https://regexlens.dev/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email Magic Links via Resend (optional)
# Get API key at: https://resend.com
AUTH_RESEND_KEY=
# Local: noreply@localhost — Production: use an address on a domain you verify in Resend
EMAIL_FROM=noreply@localhost

# ===========================================
# Rate Limiting - Vercel KV (optional)
# ===========================================
# Rate limiting is disabled when these are not set (fine for local dev)
# Set up at: https://vercel.com/dashboard (Storage > KV)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ===========================================
# Site Configuration
# ===========================================
# Public site URL (metadata, canonical URLs, sitemap, legal pages).
# Production: https://regexlens.dev — for local dev you can override in .env.local:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://regexlens.dev

# Documentation (Nextra on GitHub Pages — custom subdomain)
NEXT_PUBLIC_DOCS_URL=https://docs.regexlens.dev

# Vercel Web Analytics + Speed Insights (@vercel/analytics, @vercel/speed-insights)
# Set to 0 to disable instrumentation client bundles locally or on a preview
# NEXT_PUBLIC_VERCEL_ANALYTICS=0

# Ads (optional) — enable only after you have a consent/CMP strategy for your regions
# NEXT_PUBLIC_ADS_ENABLED=1
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx

# Sponsorship / support link (optional)
# NEXT_PUBLIC_SUPPORT_URL=https://buymeacoffee.com/nanaagyei

# ===========================================
# SEO Verification (optional)
# ===========================================
# Google Search Console verification code
GOOGLE_SITE_VERIFICATION=

# Yandex Webmaster verification code
YANDEX_VERIFICATION=

# Bing Webmaster verification code (if needed)
# BING_VERIFICATION=
