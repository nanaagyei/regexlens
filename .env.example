# ===========================================
# RegexLens Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# ===========================================
# Database (Docker default - no changes needed for local dev)
# ===========================================
DATABASE_URL=postgresql://regexlens:regexlens_dev@localhost:5432/regexlens

# ===========================================
# Authentication (Auth.js)
# ===========================================
# REQUIRED: Generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth (required - at least one OAuth provider needed)
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (optional)
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email Magic Links via Resend (optional)
# Get API key at: https://resend.com
AUTH_RESEND_KEY=
EMAIL_FROM=noreply@localhost

# ===========================================
# Stripe Billing (optional - for Pro features)
# ===========================================
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# ===========================================
# Rate Limiting - Vercel KV (optional)
# ===========================================
# Rate limiting is disabled when these are not set (fine for local dev)
# Set up at: https://vercel.com/dashboard (Storage > KV)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ===========================================
# Site Configuration
# ===========================================
# Your production URL (used for SEO, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=https://regexlens.dev

# ===========================================
# SEO Verification (optional)
# ===========================================
# Google Search Console verification code
GOOGLE_SITE_VERIFICATION=

# Yandex Webmaster verification code
YANDEX_VERIFICATION=

# Bing Webmaster verification code (if needed)
# BING_VERIFICATION=
